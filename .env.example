# ArcSwap — environment variables template
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
#   cp .env.example .env
#   chmod 600 .env

# ─── IPFS pinning providers ──────────────────────────────────────────────────
# web3.storage UCAN token (https://console.web3.storage)
WEB3_STORAGE_TOKEN=

# Pinata JWT (https://app.pinata.cloud/developers/api-keys)
PINATA_JWT=

# ─── Production hosts ────────────────────────────────────────────────────────
# Primary domain (Cloudflare Pages)
APP_URL=https://arcswap.net

# Optional decentralized backup via ENS+IPFS (set up later — see DEPLOYMENT.md)
APP_BACKUP_URL=https://arcswap.eth.limo
ENS_NAME=arcswap.eth
ENS_RESOLVER=0x231b0Ee14048e9dCcD1d247744d114a4EB5E8E63

# ─── Cloudflare ──────────────────────────────────────────────────────────────
# For wrangler CLI deploys (https://dash.cloudflare.com/profile/api-tokens)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PROJECT_NAME=arcswap

# ─── Arc network ─────────────────────────────────────────────────────────────
ARC_RPC=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002

# ─── Circle CCTP (testnet sandbox; switch to mainnet for prod) ───────────────
IRIS_BASE=https://iris-api-sandbox.circle.com/v2

# ─── Contract addresses (read-only — frontend doesn't need a private key) ────
USYC_TELLER=0x9fdF14c5B14173D74C08Af27AebFf39240dC105A
USYC_TOKEN=0xe9185Fb1bcEEEF1FDE04F9596c4F2E01d25adb86C
EURC_TOKEN=0x89B5b66B1A3FbFC1c9C43Aa01c2a8c7f0C19D72a
UNISWAP_V2_ROUTER=0x48a9bd1644ac67fbef4183261c466bea3eb333fc
UNISWAP_V2_FACTORY=0x45dd35611179ae6663ae47791175d7d598ced086
TOKEN_MESSENGER_V2=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA

# ─── Monitoring / alerting ───────────────────────────────────────────────────
# Discord or Slack incoming webhook for health-check.sh alerts.
# Discord: https://support.discord.com/hc/en-us/articles/228383668
# Slack:   https://api.slack.com/messaging/webhooks
ALERT_WEBHOOK=

# Tenderly (smart contract monitoring)
TENDERLY_PROJECT=
TENDERLY_USERNAME=
TENDERLY_ACCESS_KEY=

# ─── Multi-sig (read-only references — keys live in hardware wallets) ────────
TREASURY_SAFE=
ENS_CONTROLLER_SAFE=
CONTRACT_OWNER_SAFE=

# ─── DO NOT add deployer private keys here ───────────────────────────────────
# Use a hardware wallet for any signing. If you ABSOLUTELY need a hot key for
# CI (e.g. testnet faucet drip), use a dedicated address with minimal funds and
# store the key in your CI provider's encrypted secrets — never in this file.
