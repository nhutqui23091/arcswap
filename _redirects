# Cloudflare Pages tự động phục vụ /vault.html ở cả /vault và /vault.html
# (auto-redirect /vault.html → /vault để tránh duplicate). KHÔNG được thêm rule
# rewrite kiểu "/vault /vault.html 200" — sẽ tạo infinite redirect loop.
#
# File này giữ:
# 1. LEGACY alias (URL cũ trỏ sang URL mới)
# 2. PRETTY URL cho blog post (vd /blog/usyc-explained → /blog-usyc.html)

# Legacy aliases
/swap    /trade   301
/bridge  /trade   301
/farm    /token   302

# Disabled pages — redirect to active feature
/point   /trade   302
/points  /trade   302

# Old flat blog URLs → 301 redirect tới pretty nested URLs
# (đặt TRƯỚC rule rewrite để 301 chạy trước, /blog/... rewrite sau)
/blog-launch        /blog/launch-arc-testnet      301
/blog-launch.html   /blog/launch-arc-testnet      301
/blog-arcswap       /blog/what-is-arcswap         301
/blog-arcswap.html  /blog/what-is-arcswap         301
/blog-usyc          /blog/usyc-explained          301
/blog-usyc.html     /blog/usyc-explained          301

# Blog post pretty URLs (rewrite, không redirect — URL hiện vẫn là /blog/...)
/blog/usyc-explained        /blog-usyc.html       200
/blog/what-is-arcswap       /blog-arcswap.html    200
/blog/launch-arc-testnet    /blog-launch.html     200
