# Cloudflare Pages tự động phục vụ /vault.html ở cả /vault và /vault.html
# (auto-redirect /vault.html → /vault để tránh duplicate). KHÔNG được thêm rule
# rewrite kiểu "/vault /vault.html 200" — sẽ tạo infinite redirect loop.
#
# File này giữ:
# 1. LEGACY alias (URL cũ trỏ sang URL mới)
# 2. PRETTY URL cho blog post (vd /blog/usyc-explained → /blog-usyc.html)

# Legacy aliases
/swap    /trade   301
/bridge  /trade   301
/farm    /token   302

# Disabled pages — redirect to active feature
/point   /trade   302
/points  /trade   302

# Blog posts giờ là file thật trong /blog/<slug>.html
# Cloudflare Pages tự strip .html → URL đẹp /blog/<slug>. KHÔNG dùng 200 rewrite
# từ /blog/<slug> → /blog-<slug>.html nữa — gây infinite redirect loop với
# auto-strip-.html của Cloudflare.

# Old flat URLs → 301 sang URL mới
/blog-launch        /blog/launch-arc-testnet      301
/blog-arcswap       /blog/what-is-arcswap         301
/blog-usyc          /blog/usyc-explained          301
