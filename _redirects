# Legacy aliases
# Cloudflare Pages applies these BEFORE static file matching, so old URLs
# for surfaces we dropped (Vault / Pool / Points / USYC blog / DEX deploy)
# now redirect cleanly instead of 404-ing.

# GM campaign renamed to Portal — keep old links (tweets, blog) working.
/gm      /portal  301

/swap    /trade   301
/bridge  /trade   301
/farm    /token   302
/deploy  /token   301

# Dropped surfaces — redirect to nearest live page
/vault   /balance 301
/vaults  /balance 301
/pool    /trade   301
/pools   /trade   301
/point   /trade   302
/points  /trade   302

# Dropped blog post — redirect to blog index
/blog/usyc-explained   /blog   301
/blog-usyc             /blog   301

# Status page lives on its own subdomain (separate Cloudflare Pages project for
# cache isolation + independent uptime). Forward any legacy /status URLs.
/status     https://status.oneliq.xyz/   301
/status/*   https://status.oneliq.xyz/:splat   301

# Blog posts giờ là file thật trong /blog/<slug>.html
# Cloudflare Pages tự strip .html → URL đẹp /blog/<slug>. KHÔNG dùng 200 rewrite
# từ /blog/<slug> → /blog-<slug>.html nữa — gây infinite redirect loop với
# auto-strip-.html của Cloudflare.

# Old flat URLs → 301 sang URL mới
/blog-launch        /blog/launch-arc-testnet      301
/blog-arcswap       /blog/what-is-arcswap         301
/blog-agent         /blog/launch-agent            301

# ─── Defense-in-depth: block direct access to source/internal files ──────────
# These should never exist in a deploy, but if a future `wrangler pages deploy`
# accidentally uploads them (gitignored ≠ deploy-ignored), CF returns 404.
# Note: Pages Function source files (functions/**) and config (_headers,
# _redirects, wrangler.toml) are NOT actually served — SPA fallback hides them.
# Listed below mostly for paths that ARE servable as static.
/INVESTOR-DECK.md      /404   404
/INVESTOR-DECK.pptx    /404   404
/scripts/*             /404   404
/workers/*             /404   404
/.env                  /404   404
/.env.*                /404   404
