# Headers for status.arcswap.net — a separate Cloudflare Pages project rooted
# at /status. Tighter than the main site's _headers because this page does not
# load Circle App Kit, ethers.js CDN, or any non-self scripts.
#
# These headers sit on top of the CSP meta tag baked into status/index.html.
# frame-ancestors CANNOT be set via meta — only here.

/*
  # Defense-in-depth CSP (matches the <meta> in index.html plus frame-ancestors).
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://arcswap.net https://www.arcswap.net https://rpc.testnet.arc.network https://ethereum-sepolia-rpc.publicnode.com https://sepolia.base.org https://api.avax-test.network https://sepolia-rollup.arbitrum.io https://optimism-sepolia.publicnode.com https://rpc-amoy.polygon.technology https://sepolia.unichain.org https://iris-api-sandbox.circle.com; base-uri 'self'; form-action 'self'; object-src 'none'; frame-ancestors 'none'

  # Never embeddable
  X-Frame-Options: DENY

  # HTTPS for 1 year. NOT preloading separately — subdomain inherits from
  # arcswap.net's preload entry once that's submitted to the browser preload list.
  Strict-Transport-Security: max-age=31536000; includeSubDomains

  # No MIME sniffing
  X-Content-Type-Options: nosniff

  # Don't leak full URL to third-party origins (probes use Origin only)
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser features we never use
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()

  # Cross-origin isolation
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-site

# Override Cache-Control for JS/CSS so users never get stuck on stale logic
# after a deploy. Cloudflare Pages default is max-age=14400 (4h) which means
# a tab loaded before a deploy keeps the old JS for up to 4 hours. For a
# status page that needs to reflect fresh telemetry behavior immediately,
# revalidate-on-every-request is correct: Cloudflare's 304 path keeps it
# fast (no body re-download), but the browser always asks the edge whether
# the asset changed.
/assets/*
  Cache-Control: no-cache, must-revalidate
