# ─── Claude Code local state (per-developer settings + tool result cache) ───
.claude/
UsersPC*
**/tool-results/

# ─── Secrets ─────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.keystore
.secret
secrets/

# ─── Build artifacts ─────────────────────────────────────────────────────────
dist/
build/
out/
.cache/
.parcel-cache/
.vite/
.next/
.nuxt/

# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
package-lock.json.bak

# ─── Releases ────────────────────────────────────────────────────────────────
